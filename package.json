{
  "name": "skill-tree-skills",
  "version": "0.1.0",
  "description": "Vendor-neutral Agent Skills for repository documentation, FUTURE.md workflows, and Unity-specific variants.",
  "license": "MIT",
  "private": true,
  "type": "commonjs",
  "bin": {
    "skill-tree-skills-install": "bin/install.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "sync": "python3 scripts/sync_skill_references.py",
    "sync:check": "python3 scripts/sync_skill_references.py --check",
    "validate": "python3 scripts/validate_skill_repository.py --strict",
    "test:py": "python3 -m unittest discover -s tests -p 'test_*.py'",
    "test:node": "node --test tests/test_installer.js tests/test_provider_matrix.js"
  }
}
